# Получи ключ на https://openrouter.ai/keys (бесплатные модели доступны без оплаты,
# но иногда требуется небольшой депозит для увеличения rate limit).
OPENROUTER_API_KEY=

# Модель по умолчанию. Бесплатные варианты:
#   google/gemini-2.0-flash-exp:free
#   google/gemini-flash-1.5-8b
#   meta-llama/llama-3.1-8b-instruct:free
MODEL=google/gemini-2.0-flash-exp:free

# Порт сервера
PORT=3000

# (Опционально) для рейтинга OpenRouter
APP_URL=http://localhost:3000
APP_TITLE=Lin-Lingua
